PORT=5000
NODE_ENV=development

# PostgreSQL
# Local/dev default:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=factory_db
DB_USER=postgres
DB_PASSWORD=your_password

# Cloud (Supabase Postgres — same project as Storage).
# Prefer Transaction pooler (port 6543) for Vercel/serverless; Session (5432) is capped ~15 clients.
# DB_HOST=aws-0-REGION.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.YOUR_PROJECT_REF
# DB_PASSWORD=your_database_password
# PGSSLMODE=require
# DB_POOL_MAX=1

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS, comma-separated when needed
CLIENT_ORIGIN=http://localhost:3000

# Auth cookie lifetime (milliseconds)
COOKIE_MAX_AGE_MS=604800000

# Optional: test DB override for integration tests
TEST_DB_NAME=factory_test_db
DB_ADMIN_DB=postgres

# One-time admin bootstrap vars (used by npm run bootstrap:admin)
BOOTSTRAP_ADMIN_NAME=Factory Admin
BOOTSTRAP_ADMIN_EMAIL=admin@factory.com
BOOTSTRAP_ADMIN_PASSWORD=change_me
FORCE_BOOTSTRAP_ADMIN=false

# Payroll auto-calculation policy
PAYROLL_WORK_HOURS_PER_DAY=8
PAYROLL_WORKING_DAYS_PER_MONTH=30
PAYROLL_OVERTIME_MULTIPLIER=1.25

# Device ingestion (fingerprint connector -> backend)
DEVICE_INGEST_API_KEY=change_me_device_ingest_key

# Supabase Storage (file uploads) + same project used for Postgres above
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_KEY=your-supabase-service-role-key-or-anon-key
# SUPABASE_BUCKET=factory-uploads
