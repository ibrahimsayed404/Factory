PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=factory_db
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# Frontend origin(s) for CORS, comma-separated when needed
CLIENT_ORIGIN=http://localhost:3000

# Auth cookie lifetime (milliseconds)
COOKIE_MAX_AGE_MS=604800000

# Optional: test DB override for integration tests
TEST_DB_NAME=factory_test_db
DB_ADMIN_DB=postgres

# One-time admin bootstrap vars (used by npm run bootstrap:admin)
BOOTSTRAP_ADMIN_NAME=Factory Admin
BOOTSTRAP_ADMIN_EMAIL=admin@factory.com
BOOTSTRAP_ADMIN_PASSWORD=Mazika2day
FORCE_BOOTSTRAP_ADMIN=false

# Payroll auto-calculation policy
PAYROLL_WORK_HOURS_PER_DAY=8
PAYROLL_WORKING_DAYS_PER_MONTH=30
PAYROLL_OVERTIME_MULTIPLIER=1.25

# Device ingestion (fingerprint connector -> backend)
DEVICE_INGEST_API_KEY=change_me_device_ingest_key
