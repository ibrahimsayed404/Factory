{
  "name": "factory-api",
  "version": "1.0.0",
  "description": "Clothes Factory Management System API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:ensure": "node scripts/ensure-db.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "seed:sample": "node scripts/seed-sample-data.js",
    "seed:loan": "node scripts/seed-loan-test.js",
    "migrate": "npm run db:ensure && node scripts/run-migration.js",
    "test": "jest tests/unit",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration --runInBand",
    "lint": "eslint src --ext .js",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "pg": "^8.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "supertest": "^7.1.0"
  }
}
