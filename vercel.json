{
  "version": 2,
  "builds": [
    {
      "src": "factory-client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["factory-api/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "factory-client/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/payroll/auto-run",
      "schedule": "0 0 * * *"
    }
  ]
}
